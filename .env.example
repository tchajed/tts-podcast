# Fly.io (used by flyctl CLI, not the app itself)
FLY_API_TOKEN=fo1_...

# Required
DATABASE_URL=sqlite:///data/podcast.db
AWS_ACCESS_KEY_ID=tid_...
AWS_SECRET_ACCESS_KEY=tsec_...
AWS_ENDPOINT_URL_S3=https://fly.storage.tigris.dev
AWS_REGION=auto
BUCKET_NAME=your-bucket-name
ANTHROPIC_API_KEY=sk-ant-...
ADMIN_TOKEN=your-admin-token

# Google Cloud API key (Cloud Text-to-Speech API must be enabled)
GOOGLE_TTS_API_KEY=AIza...
# Google AI Studio API key (for Gemini image generation)
GOOGLE_STUDIO_API_KEY=AIza...

# Optional
GOOGLE_TTS_VOICE=en-US-Journey-D
HOST=0.0.0.0
PORT=8080
PUBLIC_URL=https://your-app.fly.dev
WORKER_POLL_INTERVAL_SECS=5
MAX_JOB_ATTEMPTS=3
GENERATE_IMAGES=true
STATIC_DIR=../frontend/build
